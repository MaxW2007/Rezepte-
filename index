<script>
// ── STATE ──
let recipes = JSON.parse(localStorage.getItem('kochliste_recipes') || '[]');
let plan    = JSON.parse(localStorage.getItem('kochliste_plan')    || '{}');
let shoppingList = JSON.parse(localStorage.getItem('kochliste_list') || '[]');

function save() {
  localStorage.setItem('kochliste_recipes', JSON.stringify(recipes));
  localStorage.setItem('kochliste_plan',    JSON.stringify(plan));
  localStorage.setItem('kochliste_list',    JSON.stringify(shoppingList));
}

// ── NAVIGATION ──
function showPage(name) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));

  document.getElementById('page-' + name).classList.add('active');
  document.querySelectorAll('.tab').forEach(t => {
    if (t.textContent.toLowerCase().includes(name === 'rezepte' ? 'rezept' : name === 'planen' ? 'plan' : 'einkauf'))
      t.classList.add('active');
  });
  document.getElementById('nav-' + name).classList.add('active');

  if (name === 'planen') renderPlan();
  if (name === 'liste')  renderList();
}

// ── TOAST ──
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}

// ── INGREDIENT ROWS ──
function addIngredientRow(name='', amount='', unit='') {
  const container = document.getElementById('ingredients-list');
  const row = document.createElement('div');
  row.className = 'ingredient-row';
  row.innerHTML = `
    <input type="text" placeholder="Tomaten" value="${name}" />
    <input type="number" placeholder="400" value="${amount}" min="0" step="0.1" />
    <input type="text" placeholder="g / ml / Stk" value="${unit}" />
    <button class="remove-ing-btn" onclick="this.parentElement.remove()">✕</button>
  `;
  container.appendChild(row);
}

// ── SAVE RECIPE ──
function saveRecipe() {
  const name = document.getElementById('recipe-name').value.trim();
  const portions = parseInt(document.getElementById('recipe-portions').value) || 4;
  if (!name) { showToast('⚠️ Bitte Rezeptname eingeben'); return; }

  const rows = document.querySelectorAll('#ingredients-list .ingredient-row');
  const ingredients = [];
  rows.forEach(row => {
    const inputs = row.querySelectorAll('input');
    const ingName = inputs[0].value.trim();
    const amount  = inputs[1].value.trim();
    const unit    = inputs[2].value.trim();
    if (ingName) ingredients.push({ name: ingName, amount: parseFloat(amount) || 0, unit });
  });

  if (!ingredients.length) { showToast('⚠️ Mindestens eine Zutat angeben'); return; }

  const recipe = { id: Date.now(), name, portions, ingredients };
  recipes.push(recipe);
  plan[recipe.id] = 0;
  save();

  // reset form
  document.getElementById('recipe-name').value = '';
  document.getElementById('recipe-portions').value = '4';
  document.getElementById('ingredients-list').innerHTML = '';

  renderRecipes();
  showToast('✅ Rezept gespeichert!');
}

// ── RENDER RECIPES ──
function renderRecipes() {
  const c = document.getElementById('recipes-container');
  if (!recipes.length) {
    c.innerHTML = '<p style="color:var(--text-muted); font-size:0.9rem; text-align:center; padding:20px">Noch keine Rezepte. Erstelle dein erstes Rezept oben!</p>';
    return;
  }
  c.innerHTML = recipes.map(r => `
    <div class="card recipe-card">
      <div>
        <div class="recipe-name">${r.name}</div>
        <div class="recipe-portions-label">Für ${r.portions} Portionen</div>
        <div class="recipe-ingredients">${r.ingredients.map(i =>
          `${i.amount ? i.amount + ' ' : ''}${i.unit ? i.unit + ' ' : ''}${i.name}`
        ).join(' · ')}</div>
      </div>
      <div class="recipe-actions">
        <button class="delete-btn" onclick="deleteRecipe(${r.id})">🗑 löschen</button>
      </div>
    </div>
  `).join('');
}

function deleteRecipe(id) {
  recipes = recipes.filter(r => r.id !== id);
  delete plan[id];
  save();
  renderRecipes();
  showToast('Rezept gelöscht');
}

// ── RENDER PLAN ──
function renderPlan() {
  const c = document.getElementById('plan-container');
  if (!recipes.length) {
    c.innerHTML = '<div class="empty-state"><div class="icon">🍽️</div><p>Erst Rezepte anlegen,<br>dann hier planen!</p></div>';
    return;
  }
  c.innerHTML = recipes.map(r => {
    const count = plan[r.id] || 0;
    return `
      <div class="card recipe-card">
        <div>
          <div class="recipe-name">${r.name}</div>
          <div class="recipe-portions-label">
            ${r.portions} Portionen Grundrezept
            ${count > 0 ? `· <span class="selected-badge">×${count} ausgewählt</span>` : ''}
          </div>
          <div class="recipe-ingredients">${r.ingredients.length} Zutaten</div>
        </div>
        <div class="recipe-actions">
          <div class="counter">
            <button class="counter-btn minus" onclick="updatePlan(${r.id}, -1)">−</button>
            <span class="counter-val" id="plan-count-${r.id}">${count}</span>
            <button class="counter-btn plus" onclick="updatePlan(${r.id}, 1)">+</button>
          </div>
        </div>
      </div>
    `;
  }).join('');
}

function updatePlan(id, delta) {
  plan[id] = Math.max(0, (plan[id] || 0) + delta);
  save();
  const el = document.getElementById('plan-count-' + id);
  if (el) el.textContent = plan[id];
  // update badge
  renderPlan();
}

// ── GENERATE LIST ──
function generateList() {
  const totals = {}; // key: "name|unit" → { name, unit, amount }

  recipes.forEach(r => {
    const times = plan[r.id] || 0;
    if (!times) return;
    // scale factor: times * (1 portion = 1/r.portions of recipe)
    const factor = times;
    r.ingredients.forEach(ing => {
      const key = ing.name.toLowerCase() + '|' + ing.unit.toLowerCase();
      if (!totals[key]) totals[key] = { name: ing.name, unit: ing.unit, amount: 0 };
      totals[key].amount += ing.amount * factor;
    });
  });

  shoppingList = Object.values(totals).map(item => ({
    ...item,
    checked: false,
    id: Math.random().toString(36).slice(2)
  }));

  if (!shoppingList.length) {
    showToast('⚠️ Kein Rezept ausgewählt!');
    return;
  }

  save();
  showPage('liste');
  showToast('✅ Einkaufsliste erstellt!');
}

// ── RENDER LIST ──
function renderList() {
  const c = document.getElementById('list-container');
  if (!shoppingList.length) {
    c.innerHTML = `<div class="empty-state"><div class="icon">🛒</div><p>Gehe zu <strong>Planen</strong>,<br>wähle Rezepte aus und<br>generiere die Liste!</p></div>`;
    return;
  }

  // group by unit type (rough categorization)
  const cats = {};
  shoppingList.forEach(item => {
    const cat = getCategory(item.name, item.unit);
    if (!cats[cat]) cats[cat] = [];
    cats[cat].push(item);
  });

  c.innerHTML = Object.entries(cats).map(([cat, items]) => `
    <div class="shopping-category">
      <div class="category-title">${cat}</div>
      ${items.map(item => `
        <div class="shopping-item ${item.checked ? 'checked' : ''}" onclick="toggleItem('${item.id}')">
          <div class="check-box">${item.checked ? '✓' : ''}</div>
          <span class="item-name">${item.name}</span>
          ${item.amount ? `<span class="item-amount">${formatAmount(item.amount)} ${item.unit}</span>` : ''}
        </div>
      `).join('')}
    </div>
  `).join('');
}

function getCategory(name, unit) {
  const n = name.toLowerCase();
  const u = unit.toLowerCase();
  if (['g','kg','ml','l'].includes(u)) {
    if (/mehl|zucker|salz|pfeffer|öl|essig|butter|sahne|milch/.test(n)) return '🧂 Grundzutaten';
    if (/fleisch|hähnchen|rind|schwein|fisch|lachs|thunfisch/.test(n)) return '🥩 Fleisch & Fisch';
    if (/käse|joghurt|ei|eier/.test(n)) return '🥚 Kühlregal';
  }
  if (/tomate|paprika|zwiebel|knoblauch|karotte|salat|gurke|brokkoli|spinat/.test(n)) return '🥦 Gemüse';
  if (/apfel|banane|zitrone|orange|beere/.test(n)) return '🍎 Obst';
  if (/nudel|pasta|reis|brot|mehl/.test(n)) return '🌾 Getreide & Brot';
  if (/dose|konserv/.test(n)) return '🥫 Konserven';
  return '🛒 Sonstiges';
}

function formatAmount(val) {
  if (val === Math.floor(val)) return val;
  return Math.round(val * 10) / 10;
}

function toggleItem(id) {
  const item = shoppingList.find(i => i.id === id);
  if (item) { item.checked = !item.checked; save(); renderList(); }
}

function clearChecked() {
  shoppingList = shoppingList.filter(i => !i.checked);
  save();
  renderList();
  showToast('Erledigte Einträge gelöscht');
}

// ── PWA INSTALL ──
let deferredPrompt;
window.addEventListener('beforeinstallprompt', e => {
  e.preventDefault();
  deferredPrompt = e;
  document.getElementById('install-banner').classList.add('visible');
});

document.getElementById('install-btn').addEventListener('click', async () => {
  if (!deferredPrompt) return;
  deferredPrompt.prompt();
  const { outcome } = await deferredPrompt.userChoice;
  if (outcome === 'accepted') showToast('🎉 App installiert!');
  deferredPrompt = null;
  dismissInstall();
});

function dismissInstall() {
  document.getElementById('install-banner').classList.remove('visible');
}

// ── INIT ──
addIngredientRow();
renderRecipes();
</script>

